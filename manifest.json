{
  "manifest_version": 3,
  "name": "Check Access Local",
  "description": "Vérification de l'accessibilité des sites AEM",
  "version": "2.0",
  "icons": {
    "16": "a11y/images/icon-16.png",
    "32": "a11y/images/icon-32.png",
    "48": "a11y/images/icon-48.png",
    "128": "a11y/images/icon-128.png",
    "180": "a11y/images/icon-180.png"
  },
  "background": {
    "service_worker": "sw_chrome_local.js"
  },
  "action": {
    "default_icon": {
      "16": "a11y/images/icon-16.png",
      "32": "a11y/images/icon-32.png",
      "48": "a11y/images/icon-48.png",
      "128": "a11y/images/icon-128.png",
      "180": "a11y/images/icon-180.png"
    }
  },
  "permissions": ["scripting", "activeTab"],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+B",
        "mac": "Command+B"
      }
    }
  }
}